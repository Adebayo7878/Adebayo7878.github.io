<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anewar Adjibade — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --blue: #1a3aff;
    --blue-light: #4d7cff;
    --blue-pale: #a8c4ff;
    --red: #ff2244;
    --red-light: #ff6080;
    --dark: #03040f;
    --dark2: #080c1e;
    --dark3: #0d1535;
    --star: #e8f0ff;
    --glow-blue: 0 0 20px rgba(26,58,255,0.6), 0 0 60px rgba(26,58,255,0.2);
    --glow-red: 0 0 20px rgba(255,34,68,0.6), 0 0 60px rgba(255,34,68,0.2);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--star);
    font-family: 'Rajdhani', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR */
  .cursor {
    position: fixed; width: 12px; height: 12px;
    background: var(--red); border-radius: 50%;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s, width 0.3s, height 0.3s, background 0.3s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    position: fixed; width: 36px; height: 36px;
    border: 1.5px solid var(--blue-light);
    border-radius: 50%; pointer-events: none; z-index: 9998;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease-out, width 0.3s, height 0.3s;
  }

  /* STARS CANVAS */
  #starfield { position: fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; }

  /* SCANLINE OVERLAY */
  body::after {
    content:''; position:fixed; inset:0; z-index:1;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events:none;
  }

  /* NAV */
  nav {
    position: fixed; top:0; left:0; right:0; z-index:100;
    display:flex; justify-content:space-between; align-items:center;
    padding: 1.5rem 3rem;
    background: linear-gradient(180deg, rgba(3,4,15,0.95) 0%, transparent 100%);
    backdrop-filter: blur(8px);
  }
  .nav-logo {
    font-family: 'Orbitron', monospace; font-weight:900; font-size:1rem;
    color: var(--blue-light); letter-spacing:4px;
    text-decoration:none;
  }
  .nav-logo span { color: var(--red); }
  .nav-links { display:flex; gap:2.5rem; list-style:none; }
  .nav-links a {
    font-family: 'Space Mono', monospace; font-size:0.7rem;
    color: var(--blue-pale); text-decoration:none; letter-spacing:2px;
    text-transform:uppercase; transition: color 0.3s;
    position:relative;
  }
  .nav-links a::after {
    content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px;
    background: var(--red); transition: width 0.3s;
  }
  .nav-links a:hover { color:#fff; }
  .nav-links a:hover::after { width:100%; }

  /* SECTIONS */
  section { position:relative; z-index:2; }

  /* ===== HERO ===== */
  #hero {
    min-height:100vh; display:flex; flex-direction:column;
    justify-content:center; align-items:center; text-align:center;
    padding: 8rem 2rem 4rem;
    overflow:hidden;
  }

  .orbit-ring {
    position:absolute; border-radius:50%;
    border: 1px solid rgba(26,58,255,0.15);
    animation: spin linear infinite;
  }
  .orbit-ring:nth-child(1) { width:600px; height:600px; animation-duration:30s; }
  .orbit-ring:nth-child(2) { width:900px; height:900px; animation-duration:50s; animation-direction:reverse; border-color: rgba(255,34,68,0.08); }
  .orbit-ring:nth-child(3) { width:1200px; height:1200px; animation-duration:70s; }

  .orbit-dot {
    position:absolute; width:6px; height:6px; border-radius:50%;
    background: var(--blue-light); box-shadow: var(--glow-blue);
    top: -3px; left:50%; transform:translateX(-50%);
  }
  .orbit-ring:nth-child(2) .orbit-dot { background: var(--red); box-shadow: var(--glow-red); }

  @keyframes spin { from { transform:rotate(0deg); } to { transform:rotate(360deg); } }

  .hero-tag {
    font-family:'Space Mono', monospace; font-size:0.65rem;
    color: var(--red-light); letter-spacing:4px; text-transform:uppercase;
    margin-bottom:1rem;
    animation: fadeUp 1s 0.2s both;
  }

  .hero-name {
    font-family:'Orbitron', monospace; font-weight:900;
    font-size: clamp(2.5rem, 7vw, 6rem);
    line-height:1;
    background: linear-gradient(135deg, #fff 0%, var(--blue-pale) 50%, var(--blue-light) 100%);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    animation: fadeUp 1s 0.4s both;
    letter-spacing:2px;
  }

  .hero-subtitle {
    font-family:'Rajdhani', sans-serif; font-weight:300; font-size:1.3rem;
    color: var(--blue-pale); margin-top:1rem; letter-spacing:6px;
    text-transform:uppercase;
    animation: fadeUp 1s 0.6s both;
  }

  .hero-desc {
    max-width:500px; margin:2rem auto; font-size:1rem; line-height:1.8;
    color: rgba(168,196,255,0.7); font-weight:300;
    animation: fadeUp 1s 0.8s both;
  }

  .hero-btns {
    display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;
    animation: fadeUp 1s 1s both;
  }
  .btn-primary {
    padding:0.9rem 2.5rem; font-family:'Orbitron', monospace; font-size:0.7rem;
    letter-spacing:3px; text-transform:uppercase; text-decoration:none;
    background: var(--blue); color:#fff; border:none;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    transition: background 0.3s, box-shadow 0.3s; cursor:none;
    box-shadow: var(--glow-blue);
  }
  .btn-primary:hover { background: var(--blue-light); box-shadow: 0 0 40px rgba(77,124,255,0.8); }
  .btn-outline {
    padding:0.9rem 2.5rem; font-family:'Orbitron', monospace; font-size:0.7rem;
    letter-spacing:3px; text-transform:uppercase; text-decoration:none;
    background:transparent; color:var(--red-light);
    border: 1px solid var(--red);
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    transition: background 0.3s, box-shadow 0.3s; cursor:none;
  }
  .btn-outline:hover { background: rgba(255,34,68,0.1); box-shadow: var(--glow-red); }

  .scroll-indicator {
    position:absolute; bottom:2rem; left:50%; transform:translateX(-50%);
    display:flex; flex-direction:column; align-items:center; gap:0.5rem;
    font-family:'Space Mono', monospace; font-size:0.6rem;
    color: var(--blue-pale); letter-spacing:3px; text-transform:uppercase;
    animation: fadeUp 1s 1.5s both;
  }
  .scroll-line {
    width:1px; height:40px;
    background: linear-gradient(180deg, var(--blue), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.3;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.2)} }

  /* ===== ABOUT ===== */
  #about {
    padding: 8rem 3rem;
    display:flex; flex-wrap:wrap; gap:5rem;
    justify-content:center; align-items:center;
    max-width:1200px; margin:0 auto;
  }

  .photo-container {
    position:relative; flex-shrink:0;
    width:280px; height:340px;
  }
  .photo-frame {
    width:100%; height:100%;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    overflow:hidden; position:relative;
  }
  .photo-frame img {
    width:100%; height:100%; object-fit:cover; object-position: center top;
    filter: saturate(0.9) contrast(1.05);
  }
  .photo-frame::after {
    content:''; position:absolute; inset:0;
    background: linear-gradient(135deg, rgba(26,58,255,0.15) 0%, transparent 50%, rgba(255,34,68,0.1) 100%);
  }
  .photo-border-tl {
    position:absolute; top:-8px; left:-8px; width:60px; height:60px;
    border-top:2px solid var(--blue); border-left:2px solid var(--blue);
    box-shadow: var(--glow-blue);
  }
  .photo-border-br {
    position:absolute; bottom:-8px; right:-8px; width:60px; height:60px;
    border-bottom:2px solid var(--red); border-right:2px solid var(--red);
    box-shadow: var(--glow-red);
  }
  .photo-badge {
    position:absolute; bottom:-20px; left:50%; transform:translateX(-50%);
    background: var(--dark3); border:1px solid var(--blue);
    padding:0.4rem 1.2rem; font-family:'Space Mono', monospace;
    font-size:0.6rem; letter-spacing:3px; color:var(--blue-light);
    white-space:nowrap; box-shadow: var(--glow-blue);
  }

  .about-text { max-width:520px; }
  .section-label {
    font-family:'Space Mono', monospace; font-size:0.65rem;
    color:var(--red); letter-spacing:4px; text-transform:uppercase;
    margin-bottom:0.5rem;
    display:flex; align-items:center; gap:0.8rem;
  }
  .section-label::before {
    content:''; width:30px; height:1px; background:var(--red);
  }
  .section-title {
    font-family:'Orbitron', monospace; font-weight:700;
    font-size: clamp(1.8rem, 3vw, 2.8rem); line-height:1.2;
    margin-bottom:1.5rem;
    background: linear-gradient(90deg, #fff 0%, var(--blue-pale) 100%);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  }
  .about-text p {
    font-size:1rem; line-height:1.9; color:rgba(168,196,255,0.8);
    margin-bottom:1rem; font-weight:300;
  }
  .about-text p strong { color:#fff; font-weight:600; }

  .about-stats {
    display:grid; grid-template-columns:repeat(3,1fr); gap:1rem;
    margin-top:2.5rem;
  }
  .stat-box {
    background: rgba(26,58,255,0.07);
    border: 1px solid rgba(26,58,255,0.2);
    padding:1rem; text-align:center;
    clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    transition: border-color 0.3s, background 0.3s;
  }
  .stat-box:hover { border-color: var(--blue-light); background: rgba(26,58,255,0.15); }
  .stat-num {
    font-family:'Orbitron', monospace; font-weight:900; font-size:1.8rem;
    color: var(--blue-light);
  }
  .stat-label {
    font-family:'Space Mono', monospace; font-size:0.55rem;
    color:var(--blue-pale); letter-spacing:2px; text-transform:uppercase;
    margin-top:0.3rem;
  }

  /* ===== SKILLS ===== */
  #skills {
    padding: 8rem 3rem;
    background: linear-gradient(180deg, transparent 0%, rgba(8,12,30,0.8) 50%, transparent 100%);
  }
  .skills-inner { max-width:1100px; margin:0 auto; }
  .skills-header { text-align:center; margin-bottom:4rem; }

  .skills-grid {
    display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr));
    gap:1.5rem;
  }
  .skill-card {
    background: rgba(8,12,30,0.8);
    border: 1px solid rgba(26,58,255,0.15);
    padding:2rem;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
    position:relative; overflow:hidden;
    transition: border-color 0.4s, transform 0.3s;
    cursor:none;
  }
  .skill-card:hover { border-color: rgba(26,58,255,0.6); transform:translateY(-4px); }
  .skill-card::before {
    content:''; position:absolute; inset:0;
    background: linear-gradient(135deg, rgba(26,58,255,0.05) 0%, transparent 100%);
    opacity:0; transition:opacity 0.4s;
  }
  .skill-card:hover::before { opacity:1; }
  .skill-card.accent { border-color: rgba(255,34,68,0.2); }
  .skill-card.accent:hover { border-color: rgba(255,34,68,0.6); }
  .skill-card.accent::before { background: linear-gradient(135deg, rgba(255,34,68,0.05) 0%, transparent 100%); }

  .skill-icon {
    font-size:2rem; margin-bottom:1rem;
    display:block; filter: drop-shadow(0 0 8px rgba(26,58,255,0.6));
  }
  .skill-card.accent .skill-icon { filter: drop-shadow(0 0 8px rgba(255,34,68,0.6)); }
  .skill-name {
    font-family:'Orbitron', monospace; font-weight:700; font-size:1rem;
    color:#fff; margin-bottom:0.5rem; letter-spacing:1px;
  }
  .skill-level-text {
    font-family:'Space Mono', monospace; font-size:0.6rem;
    color:var(--blue-pale); letter-spacing:2px; text-transform:uppercase;
    margin-bottom:1rem;
  }
  .skill-bar { height:3px; background:rgba(255,255,255,0.08); border-radius:0; overflow:hidden; }
  .skill-fill {
    height:100%; background: linear-gradient(90deg, var(--blue), var(--blue-light));
    border-radius:0;
    animation: fillBar 1.5s ease-out both;
    transform-origin: left;
  }
  .skill-card.accent .skill-fill { background: linear-gradient(90deg, var(--red), var(--red-light)); }
  @keyframes fillBar { from { width:0; } }

  /* ===== PROJECTS ===== */
  #projects { padding: 8rem 3rem; }
  .projects-inner { max-width:1100px; margin:0 auto; }
  .projects-header { text-align:center; margin-bottom:4rem; }

  .projects-grid {
    display:grid; grid-template-columns:repeat(auto-fit, minmax(320px,1fr));
    gap:2rem;
  }
  .project-card {
    background: var(--dark2);
    border: 1px solid rgba(26,58,255,0.12);
    overflow:hidden; position:relative;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
    transition: transform 0.3s, border-color 0.3s; cursor:none;
  }
  .project-card:hover { transform:translateY(-6px); border-color: rgba(26,58,255,0.5); }
  .project-card:nth-child(2n) { border-color: rgba(255,34,68,0.12); }
  .project-card:nth-child(2n):hover { border-color: rgba(255,34,68,0.5); }

  .project-header {
    padding:1.5rem 1.5rem 0;
    display:flex; justify-content:space-between; align-items:flex-start;
  }
  .project-num {
    font-family:'Orbitron', monospace; font-size:3rem; font-weight:900;
    color:rgba(26,58,255,0.12); line-height:1;
  }
  .project-card:nth-child(2n) .project-num { color:rgba(255,34,68,0.12); }
  .project-tags { display:flex; gap:0.4rem; flex-wrap:wrap; justify-content:flex-end; }
  .tag {
    padding:0.2rem 0.6rem; font-family:'Space Mono', monospace; font-size:0.55rem;
    background:rgba(26,58,255,0.15); color:var(--blue-light);
    border:1px solid rgba(26,58,255,0.3); letter-spacing:1px;
  }
  .project-card:nth-child(2n) .tag { background:rgba(255,34,68,0.1); color:var(--red-light); border-color:rgba(255,34,68,0.3); }

  .project-body { padding:0.5rem 1.5rem 1.5rem; }
  .project-name {
    font-family:'Orbitron', monospace; font-weight:700; font-size:1.1rem;
    color:#fff; margin-bottom:0.8rem; line-height:1.3;
  }
  .project-desc { font-size:0.9rem; color:rgba(168,196,255,0.7); line-height:1.8; }
  .project-link {
    display:inline-flex; align-items:center; gap:0.5rem;
    margin-top:1.5rem; font-family:'Space Mono', monospace; font-size:0.65rem;
    color:var(--blue-light); text-decoration:none; letter-spacing:2px;
    text-transform:uppercase; transition:color 0.3s;
  }
  .project-link:hover { color:#fff; }
  .project-link::after { content:'→'; }

  /* ===== PASSIONS ===== */
  #passions {
    padding: 8rem 3rem;
    background: linear-gradient(180deg, transparent 0%, rgba(8,12,30,0.8) 50%, transparent 100%);
  }
  .passions-inner { max-width:900px; margin:0 auto; text-align:center; }

  .passions-grid {
    display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:3rem;
    text-align:left;
  }
  .passion-block {
    padding:2.5rem; border:1px solid rgba(26,58,255,0.15);
    background: rgba(8,12,30,0.6); position:relative; overflow:hidden;
    transition: border-color 0.3s, transform 0.3s; cursor:none;
  }
  .passion-block:hover { border-color: rgba(26,58,255,0.5); transform:translateY(-4px); }
  .passion-block:nth-child(2) { border-color:rgba(255,34,68,0.15); }
  .passion-block:nth-child(2):hover { border-color:rgba(255,34,68,0.5); }

  .passion-icon-big { font-size:3rem; margin-bottom:1rem; display:block; }
  .passion-title {
    font-family:'Orbitron', monospace; font-weight:700; font-size:1.2rem;
    color:#fff; margin-bottom:0.8rem;
  }
  .passion-desc { font-size:0.95rem; color:rgba(168,196,255,0.7); line-height:1.9; }
  .passion-glow {
    position:absolute; width:200px; height:200px; border-radius:50%;
    top:-100px; right:-100px;
    background:radial-gradient(circle, rgba(26,58,255,0.08) 0%, transparent 70%);
    pointer-events:none;
  }
  .passion-block:nth-child(2) .passion-glow { background:radial-gradient(circle, rgba(255,34,68,0.08) 0%, transparent 70%); }

  /* ===== CONTACT ===== */
  #contact { padding: 8rem 3rem; }
  .contact-inner {
    max-width:700px; margin:0 auto; text-align:center;
  }
  .contact-links {
    display:flex; gap:1.5rem; justify-content:center;
    margin-top:3rem; flex-wrap:wrap;
  }
  .contact-link {
    display:flex; align-items:center; gap:0.8rem;
    padding:1rem 2rem; text-decoration:none;
    border:1px solid rgba(26,58,255,0.25);
    color:var(--blue-pale); font-family:'Space Mono', monospace;
    font-size:0.7rem; letter-spacing:2px; text-transform:uppercase;
    background: rgba(26,58,255,0.05);
    transition: border-color 0.3s, background 0.3s, color 0.3s;
    cursor:none;
  }
  .contact-link:hover { border-color:var(--blue-light); background:rgba(26,58,255,0.15); color:#fff; }
  .contact-link.red { border-color:rgba(255,34,68,0.25); color:var(--red-light); background:rgba(255,34,68,0.05); }
  .contact-link.red:hover { border-color:var(--red-light); background:rgba(255,34,68,0.15); color:#fff; }
  .contact-link .link-icon { font-size:1.1rem; }

  /* ===== FOOTER ===== */
  footer {
    text-align:center; padding:2rem; position:relative; z-index:2;
    font-family:'Space Mono', monospace; font-size:0.6rem;
    color:rgba(168,196,255,0.3); letter-spacing:3px; border-top:1px solid rgba(26,58,255,0.08);
  }

  /* DIVIDER */
  .divider {
    max-width:1100px; margin:0 auto;
    height:1px; background:linear-gradient(90deg, transparent, rgba(26,58,255,0.3), var(--red-light), rgba(26,58,255,0.3), transparent);
  }

  /* FADE ANIMATIONS */
  @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

  .reveal { opacity:0; transform:translateY(40px); transition: opacity 0.8s, transform 0.8s; }
  .reveal.visible { opacity:1; transform:none; }

  /* GLITCH TEXT */
  .glitch { position:relative; }
  .glitch::before, .glitch::after {
    content:attr(data-text); position:absolute; inset:0;
    -webkit-background-clip:text; background-clip:text;
    -webkit-text-fill-color:transparent;
  }
  .glitch::before {
    background: linear-gradient(135deg, var(--red) 0%, var(--red-light) 100%);
    animation: glitch1 4s infinite;
  }
  .glitch::after {
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-light) 100%);
    animation: glitch2 4s infinite;
  }
  @keyframes glitch1 {
    0%,90%,100%{clip-path:inset(0 0 100% 0);transform:translate(0)}
    91%{clip-path:inset(20% 0 50% 0);transform:translate(-3px,1px)}
    93%{clip-path:inset(60% 0 10% 0);transform:translate(2px)}
    95%{clip-path:inset(40% 0 30% 0);transform:translate(-1px)}
  }
  @keyframes glitch2 {
    0%,88%,100%{clip-path:inset(0 0 100% 0);transform:translate(0)}
    89%{clip-path:inset(50% 0 20% 0);transform:translate(3px,-1px)}
    91%{clip-path:inset(10% 0 70% 0);transform:translate(-2px)}
    93%{clip-path:inset(75% 0 5% 0);transform:translate(1px)}
  }

  /* TERMINAL BLINK */
  .blink { animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity:0; } }

  /* NEBULA BG */
  .nebula {
    position:absolute; border-radius:50%; filter:blur(80px);
    pointer-events:none;
  }
  .nebula-1 { width:500px; height:500px; top:-100px; right:-100px; background:radial-gradient(circle, rgba(26,58,255,0.06) 0%, transparent 70%); }
  .nebula-2 { width:400px; height:400px; bottom:-50px; left:-80px; background:radial-gradient(circle, rgba(255,34,68,0.05) 0%, transparent 70%); }

  @media (max-width:768px) {
    nav { padding:1rem 1.5rem; }
    .nav-links { display:none; }
    #about { flex-direction:column; padding:5rem 1.5rem; gap:3rem; }
    .about-stats { grid-template-columns:1fr 1fr 1fr; }
    .passions-grid { grid-template-columns:1fr; }
    .contact-links { flex-direction:column; align-items:center; }
  }
</style>
</head>
<body>

<canvas id="starfield"></canvas>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
